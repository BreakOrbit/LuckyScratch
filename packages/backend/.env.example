# LuckyScratch backend environment template
#
# Required values are uncommented below.
# Optional values are left commented; if you keep them commented, the backend uses
# the defaults from internal/config/config.go.

# Required
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/lucky_scratch?sslmode=disable
RPC_URL=https://sepolia.infura.io/v3/replace-me
RELAYER_PRIVATE_KEY=replace_with_hex_private_key_without_0x

# Recommended
ADMIN_TOKEN=change-me

# App
# APP_ENV=development
# LOG_LEVEL=info

# API
# API_HOST=0.0.0.0
# API_PORT=8080
# API_PUBLIC_BASE_URL=https://api.example.com
# API_READ_HEADER_TIMEOUT=5s
# API_SHUTDOWN_TIMEOUT=10s

# Database
# AUTO_MIGRATE=true
# DATABASE_MIN_CONNS=1
# DATABASE_MAX_CONNS=8
# MIGRATIONS_DIR=/abs/path/to/lucky-scratch/packages/backend/migrations

# Chain
# CHAIN_ID=11155111
# CHAIN_NAME=sepolia
# CHAIN_CONFIRMATIONS=3
# CHAIN_FINALIZATION_DEPTH=12
# CHAIN_REORG_LOOKBACK=25
# CHAIN_POLL_INTERVAL=15s

# Deployment metadata import
# DEPLOYMENTS_DIR=/abs/path/to/lucky-scratch/packages/hardhat/deployments
# AUTO_IMPORT_DEPLOYMENTS=true
# DEPLOYMENT_VERSION=v1

# Relayer
# RELAYER_MAX_BATCH_TICKETS=20
# RELAYER_MAX_GAS_COST_WEI=30000000000000000
# RELAYER_MIN_BALANCE_WEI=20000000000000000
# RELAYER_RECEIPT_SYNC_BATCH_SIZE=50
# RELAYER_RETRY_BACKOFF=30s

# Risk / sponsor budget
# RISK_GLOBAL_SPONSOR_BUDGET_WEI=500000000000000000
# RISK_DEFAULT_POOL_SPONSOR_BUDGET_WEI=100000000000000000
# RISK_USER_WINDOW=10m
# RISK_USER_WINDOW_MAX_REQUESTS=20
# RISK_REVEAL_UNIT_COST_WEI=0

# Reveal
# REVEAL_AUTH_TTL=10m
# REVEAL_SUBMIT_TIMEOUT=2m

# Zama relayer / decryption context
# Default Sepolia values are built into the backend when CHAIN_ID=11155111.
# Override them only if you need a different Zama environment.
# ZAMA_MODE=zama-relayer-sdk
# ZAMA_RELAYER_URL=https://relayer.testnet.zama.org
# ZAMA_GATEWAY_CHAIN_ID=10901
# ZAMA_API_KEY=
# ZAMA_HTTP_TIMEOUT=30s
# ZAMA_FHEVM_EXECUTOR_CONTRACT_ADDRESS=0x92C920834Ec8941d2C77D188936E1f7A6f49c127
# ZAMA_ACL_CONTRACT_ADDRESS=0xf0Ffdc93b7E186bC2f8CB3dAA75D86d1930A433D
# ZAMA_HCU_CONTRACT_ADDRESS=0xa10998783c8CF88D886Bc30307e631D6686F0A22
# ZAMA_KMS_VERIFIER_CONTRACT_ADDRESS=0xbE0E383937d564D7FF0BC3b46c51f0bF8d5C311A
# ZAMA_INPUT_VERIFIER_CONTRACT_ADDRESS=0xBBC1fFCdc7C316aAAd72E807D9b0272BE8F84DA0
# ZAMA_DECRYPTION_ADDRESS=0x5D8BD78e2ea6bbE41f26dFe9fdaEAa349e077478
# ZAMA_INPUT_VERIFICATION_ADDRESS=0x483b9dE06E4E4C7D35CCf5837A1668487406D955
# ZAMA_USER_DECRYPT_DURATION_DAYS=1
# ZAMA_MAX_USER_DECRYPT_BITS=2048

# Worker jobs
# WORKER_ID=worker-1
# JOB_CLAIM_BATCH_SIZE=8
# JOB_LOCK_TIMEOUT=10m
# JOB_INDEXER_INTERVAL=15s
# JOB_RECEIPT_SYNC_INTERVAL=15s
# JOB_RETRY_FAILED_TX_INTERVAL=45s
# JOB_VRF_CHECK_INTERVAL=2m
# JOB_RECONCILE_INTERVAL=2m
